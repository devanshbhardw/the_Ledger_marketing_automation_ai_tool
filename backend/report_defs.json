        "campaignName"
      ],
      "metrics": [
        "sent",
        "delivered",
        "opens",
        "clicks",
        "conversions"
      ],
      "computed": [
        {
          "key": "clickRate",
          "numerator": "clicks",
          "denominator": "delivered",
          "percent": true
        },
        {
          "key": "openRate",
          "numerator": "opens",
          "denominator": "delivered",
          "percent": true
        }
      ],
      "orderBy": "sent",
      "orderDesc": true,
      "limit": 50,
      "sheetTab": "MoEngage Flows"
    }
  ]
