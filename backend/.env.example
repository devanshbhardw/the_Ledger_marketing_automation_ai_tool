# Path(s) to service-account JSON key file(s) — comma-separated, one file per
# GCP project/client. Each key is matched to a site by the profile's projectId
# (profiles.json); the first file listed is the default for profiles without
# one. Each service account's email must be a Viewer on its GA4 property.
# (Alternatively set the standard GOOGLE_APPLICATION_CREDENTIALS instead.)
SERVICE_ACCOUNT_FILE=./service-account.json,./another-client.json

# Optional: GCP project id for quota/billing attribution (x-goog-user-project).
QUOTA_PROJECT_ID=

# Claude API key for AI insights. Without it, insights fall back to rule-based.
ANTHROPIC_API_KEY=
# Claude model for insights (default claude-sonnet-5).
ANTHROPIC_MODEL=claude-sonnet-5

# Redis connection (report caching + scheduled refresh)
REDIS_URL=redis://127.0.0.1:6379/0

# How long a cached report stays fresh (seconds)
CACHE_TTL_SECONDS=1800

# Background refresh interval (minutes) — warms the cache for every saved site
REFRESH_INTERVAL_MIN=30

# Frontend origin allowed by CORS
CORS_ORIGINS=http://localhost:3000
